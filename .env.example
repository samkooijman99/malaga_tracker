# GitHub Personal Access Token with "repo" scope
# https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_token_here

# GitHub repository to push flights.json into (owner/repo)
GITHUB_REPO=samkooijman99/malaga_tracker

# Telegram bot for the Bangkok tracker (bangkok_tracker.py)
# Create a bot via @BotFather, add it to the group, then read the chat id
# from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
