# Amadeus for Developers — free tier at https://developers.amadeus.com
# Register → Self-Service → create app → copy Client ID + Secret
# Use "Production" environment for real data (2000 free calls/month)
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# GitHub Personal Access Token with "repo" scope
# https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_token_here

# GitHub repository to push flights.json into (owner/repo)
GITHUB_REPO=samkooijman99/malaga_tracker
